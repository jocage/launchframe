{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "private": true,
  "packageManager": "__PACKAGE_MANAGER__",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "__CHECK_COMMAND__",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seeds/index.ts",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/lib/auth.ts --output src/db/schema/auth.ts",
    "auth:secret": "npx @better-auth/cli@latest secret"
  },
  "dependencies": {
    "better-auth": "1.3.8",
    "drizzle-orm": "0.44.x",
    "next": "16.2.x",
__DATABASE_DEPENDENCIES__
    "react": "19.2.x",
    "react-dom": "19.2.x",
__PROVIDER_PACKAGE_DEPENDENCIES__
    "server-only": "^0.0.1",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@better-auth/cli": "1.3.8",
    "@playwright/test": "1.55.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^24.0.0",
__DATABASE_DEV_DEPENDENCIES__
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "0.31.x",
    "eslint": "9.35.0",
    "eslint-config-next": "16.2.x",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unused-imports": "4.2.0",
    "globals": "16.3.0",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "^16.1.6",
    "playwright": "1.55.0",
    "prettier": "3.6.2",
    "tsx": "4.20.x",
    "typescript": "5.9.x",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
